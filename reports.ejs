<%- include('../partials/head') %>
<%- include('../partials/header') %>
<section class="page-hero compact">
  <div class="container">
    <span class="eyebrow">Bibliothèque</span>
    <h1>Anciens rapports de stage</h1>
    <p>Une base d'inspiration pour les étudiants avec titre, spécialité, résumé et année.</p>
  </div>
</section>
<section class="section">
  <div class="container reports-grid">
    <% reports.forEach(report => { %>
      <article class="info-card">
        <div class="card-top">
          <span class="badge soft"><%= report.year %></span>
          <span class="muted"><%= report.specialty %></span>
        </div>
        <h3><%= report.title %></h3>
        <p><%= report.summary %></p>
        <div class="meta wrap"><span><%= report.student_name %></span><span><a href="<%= report.file_url %>">Voir le rapport</a></span></div>
      </article>
    <% }) %>
  </div>
</section>
<%- include('../partials/footer') %>
